#!/usr/bin/env bash

set -e

GAME_NAME=$1
# Optional: path to the game folder on the host (bind-mounted into container)
# If not provided, you'll be prompted or it falls back to the baked-in copy
HOST_GAME_PATH=$2
ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
GAMES_DIR="$ROOT_DIR/games"

# If no game name provided, ask
if [[ -z "$GAME_NAME" ]]; then
    echo "=== Tribes 2 Docker — Run Game ==="
    echo ""
    echo "Available games in $GAMES_DIR/:"
    ls -1 "$GAMES_DIR/" 2>/dev/null || echo "  (none found)"
    echo ""
    read -rp "Enter game name (e.g. tribes2): " GAME_NAME
    echo ""
fi

# --- Interactive game-folder selection ---------------------------------------

# Print any auto-detected Tribes 2 install directories, one per line.
detect_game_candidates() {
    local guess
    for guess in \
        "$HOME/t2-linux" \
        "$HOME/Downloads/t2-linux" \
        "$HOME/tribes2/asgard/games/tribes2" \
        "$HOME/tribes2/asgard" \
        "$HOME/Tribes2/Linux" \
        "$HOME/tribes2" \
        "$HOME/Games/Tribes2" \
        "/media/cdrom/Tribes2/Linux" \
        "/mnt/cdrom/Tribes2/Linux" \
        "/opt/tribes2" \
        "/usr/local/games/tribes2"; do
        if [[ -d "$guess" ]] && [[ -f "$guess/tribes2.dynamic" || -f "$guess/tribes2" ]]; then
            printf '%s\n' "$guess"
        fi
    done
}

# Arrow-key folder browser (whiptail). Prints the chosen directory to stdout.
#   [up/down]            highlight a sub-folder
#   Enter / "Open"       go inside the highlighted folder
#   Tab -> "Choose ..."  select the folder you are currently in
#   Esc                  cancel
browse_for_folder() {
    local cur
    cur="$(cd "${1:-$HOME}" 2>/dev/null && pwd)" || cur="$HOME"
    while true; do
        local menu=() d note=""
        [[ "$cur" != "/" ]] && menu+=(".." ".. (go up a level)")
        while IFS= read -r d; do
            [[ -n "$d" ]] && menu+=("$d" "[folder] $d")
        done < <(find "$cur" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' 2>/dev/null | LC_ALL=C sort -f)
        [[ ${#menu[@]} -eq 0 ]] && menu+=(" " "(no sub-folders here)")
        if [[ -f "$cur/tribes2.dynamic" || -f "$cur/tribes2" ]]; then
            note="\n\n  *** Tribes 2 detected in THIS folder! ***"
        fi

        local choice rc
        if choice=$(whiptail --title "Browse for your Tribes 2 game folder" \
                --menu "Now in:  $cur$note\n\n[up/down] highlight a folder, then [Open] to go inside it.\n[Tab] over to [Choose THIS folder] to pick where you are." \
                22 78 12 "${menu[@]}" \
                --ok-button "Open" --cancel-button "Choose THIS folder" \
                3>&1 1>&2 2>&3); then
            rc=0
        else
            rc=$?
        fi

        if [[ $rc -eq 0 ]]; then            # "Open" the highlighted folder
            case "$choice" in
                " ")  : ;;
                "..") cur="$(cd "$cur/.." && pwd)" ;;
                *)    cur="$(cd "$cur/$choice" 2>/dev/null && pwd)" || true ;;
            esac
        elif [[ $rc -eq 1 ]]; then          # "Choose THIS folder"
            printf '%s\n' "$cur"
            return 0
        else                                # Esc -> cancel
            return 1
        fi
    done
}

# Top-level picker: list detected installs + a "Browse..." option.
# Prints the chosen path (empty = use the copy baked into the image).
# Returns non-zero if the user quits.
select_game_folder() {
    local cands=() c menu=()
    while IFS= read -r c; do [[ -n "$c" ]] && cands+=("$c"); done < <(detect_game_candidates)
    for c in "${cands[@]}"; do menu+=("$c" "use this: $c"); done
    menu+=("__browse__"  "Browse for a folder...")
    menu+=("__builtin__" "Use the copy baked into the image")

    local sel
    sel=$(whiptail --title "Tribes 2 - Select Game Folder" \
        --menu "Where is your Tribes 2 game folder?\n(the one containing tribes2.dynamic, base/, ...)\n\nUse the arrow keys, then Enter." \
        20 78 10 "${menu[@]}" \
        --ok-button "Select" --cancel-button "Quit" \
        3>&1 1>&2 2>&3) || return 1

    case "$sel" in
        __browse__)  browse_for_folder "${cands[0]:-$HOME}" ;;
        __builtin__) printf '' ;;
        *)           printf '%s\n' "$sel" ;;
    esac
}

# If no host game path provided, ask — graphical arrow-key menu when possible.
if [[ -z "$HOST_GAME_PATH" ]]; then
    if command -v whiptail >/dev/null 2>&1 && [[ -t 0 && -t 1 ]]; then
        if ! HOST_GAME_PATH="$(select_game_folder)"; then
            echo "No folder selected. Aborting."
            exit 1
        fi
    else
        # Plain-text fallback (no whiptail, or non-interactive terminal)
        echo "Enter the path to your Tribes 2 game directory."
        echo "(folder containing tribes2.dynamic, base/, etc.; empty = built-in copy)"
        mapfile -t CANDIDATES < <(detect_game_candidates)
        if [[ ${#CANDIDATES[@]} -gt 0 ]]; then
            echo "Detected:"
            for i in "${!CANDIDATES[@]}"; do echo "  $((i+1)). ${CANDIDATES[$i]}"; done
            read -rp "Enter a path, or a number [1-${#CANDIDATES[@]}] (default: 1): " INPUT
            INPUT="${INPUT:-1}"
            if [[ "$INPUT" =~ ^[0-9]+$ ]] && [[ "$INPUT" -ge 1 ]] && [[ "$INPUT" -le ${#CANDIDATES[@]} ]]; then
                HOST_GAME_PATH="${CANDIDATES[$((INPUT-1))]}"
            else
                HOST_GAME_PATH="$INPUT"
            fi
        else
            read -rp "Enter path (or empty for built-in): " HOST_GAME_PATH
        fi
    fi

    # Expand ~
    HOST_GAME_PATH="${HOST_GAME_PATH/#\~/$HOME}"
    echo ""
fi

# Defaults (can be overridden by per-game asgard.cfg)
GAMESCOPE_WIDTH=${GAMESCOPE_WIDTH:-1280}
GAMESCOPE_HEIGHT=${GAMESCOPE_HEIGHT:-1024}
USE_GAMESCOPE=${USE_GAMESCOPE:-1}
USE_PADSP=${USE_PADSP:-1}
SOFTWARE_GL=${SOFTWARE_GL:-1}
MESA_YEAR=${MESA_YEAR:-}
SAVE_DIRS=()
LAUNCH_CMD=""
PRE_LAUNCH=""
USE_STRACE=${USE_STRACE:-1}
GAMESCOPE_ARGS=""
HOST_WRAPPER=""
EXTRA_ENV=""

# Source per-game config if it exists
if [[ -f "$ROOT_DIR/config/$GAME_NAME.cfg" ]]; then
    source "$ROOT_DIR/config/$GAME_NAME.cfg"
fi

DOCKER_EXTRA_ARGS=()
if [[ "$SOFTWARE_GL" == "1" ]]; then
    DOCKER_EXTRA_ARGS+=(-e LIBGL_ALWAYS_SOFTWARE=1)
fi
if [[ -n "$MESA_YEAR" ]]; then
    DOCKER_EXTRA_ARGS+=(-e "MESA_EXTENSION_MAX_YEAR=$MESA_YEAR")
fi

# If a host game path is provided, bind-mount it over the container's /home/loki/game
# This avoids copying game files into the image at build time.
if [[ -n "$HOST_GAME_PATH" ]]; then
    if [[ ! -d "$HOST_GAME_PATH" ]]; then
        echo "ERROR: Host game path '$HOST_GAME_PATH' does not exist or is not a directory."
        exit 2
    fi
    HOST_GAME_PATH="$(cd "$HOST_GAME_PATH" && pwd)"  # resolve to absolute path
    # Mount read-write so the engine can write console.log / prefs / screenshots
    # into the game tree, matching how a normal local install behaves.
    DOCKER_EXTRA_ARGS+=(-v "$HOST_GAME_PATH:/home/loki/game:rw")
    echo "Bind-mounting host game: $HOST_GAME_PATH -> /home/loki/game"

    # The user's game folder only contains the original game files. The launcher
    # script and the bundled replacement fonts live in THIS repo (games/$GAME_NAME)
    # and would be hidden by the bind-mount above, so layer them back on top.
    # Docker applies mounts ordered by destination depth, so these nested mounts
    # correctly overlay onto the game mount.
    HELPER_DIR="$GAMES_DIR/$GAME_NAME"
    if [[ -f "$HELPER_DIR/run_t2.sh" ]]; then
        DOCKER_EXTRA_ARGS+=(-v "$HELPER_DIR/run_t2.sh:/home/loki/game/run_t2.sh:ro")
        echo "  + overlay launcher: run_t2.sh"
    fi
    if [[ -d "$HELPER_DIR/base/fonts" ]]; then
        DOCKER_EXTRA_ARGS+=(-v "$HELPER_DIR/base/fonts:/home/loki/game/base/fonts:ro")
        echo "  + overlay fonts:    base/fonts"
    fi
fi

for save_dir in "${SAVE_DIRS[@]}"; do
    host_dir="${save_dir%%:*}"
    container_dir="${save_dir#*:}"
    mkdir -p "$host_dir"
    DOCKER_EXTRA_ARGS+=(-v "$host_dir:$container_dir:rw")
done

# Pass /dev/dsp if available (OSS emulation via snd-pcm-oss kernel module)
if [[ -e /dev/dsp ]]; then
    DOCKER_EXTRA_ARGS+=(--device /dev/dsp)
fi

if [[ -n "$EXTRA_ENV" ]]; then
    DOCKER_EXTRA_ARGS+=(-e "$EXTRA_ENV")
fi

if [ -n "$SUDO_USER" ]; then
    sudo -u "$SUDO_USER" DISPLAY=$DISPLAY xhost +local:docker > /dev/null 2>&1
else
    xhost +local:docker > /dev/null 2>&1
fi

GAMESCOPE_CMD=""
if [[ "$USE_GAMESCOPE" == "1" ]]; then
    GAMESCOPE_CMD="gamescope -w $GAMESCOPE_WIDTH -h $GAMESCOPE_HEIGHT $GAMESCOPE_ARGS --"
fi

uid=${SUDO_UID:-$(id -u)}
if [ -n "$SUDO_USER" ]; then
    HOME=$(getent passwd "$SUDO_USER" | cut -d: -f6)
    XDG_RUNTIME_DIR="/run/user/$uid"
fi
$GAMESCOPE_CMD $HOST_WRAPPER docker run \
    --rm \
    -e DISPLAY=$DISPLAY \
    --privileged \
    --network host \
    --device /dev/snd \
    --device /dev/dri \
    --group-add=audio \
    -v /etc/machine-id:/etc/machine-id \
    -v /var/lib/dbus:/var/lib/dbus \
    -e PULSE_SERVER=unix:${XDG_RUNTIME_DIR}/pulse/native \
    -v ${XDG_RUNTIME_DIR}/pulse/native:${XDG_RUNTIME_DIR}/pulse/native \
    -v ${HOME}/.config/pulse/cookie:/home/loki/.config/pulse/cookie:ro \
    --group-add $(getent group audio | cut -d: -f3) \
    -v "${HOME}/.Xauthority:/home/loki/.Xauthority:rw" \
    -v "${HOME}/.loki:/home/loki/.loki:rw" \
    -v "/tmp/.X11-unix:/tmp/.X11-unix:rw" \
    -v "${XDG_RUNTIME_DIR}:/run/loki/$uid:rw" \
    -v "/media/cdrom:/cdrom" \
    --env=DISPLAY \
    --env=XDG_RUNTIME_DIR=/run/user/$uid \
    "${DOCKER_EXTRA_ARGS[@]}" \
    -e GAME_NAME="$GAME_NAME" \
    -e LAUNCH_CMD="$LAUNCH_CMD" \
    -e PRE_LAUNCH="$PRE_LAUNCH" \
    -e USE_STRACE="$USE_STRACE" \
    -e USE_PADSP="$USE_PADSP" \
    $GAME_NAME \
    bash --norc -c 'cd /home/loki/game && export LD_LIBRARY_PATH=/usr/lib:./lib:$LD_LIBRARY_PATH && [ -n "$PRE_LAUNCH" ] && eval "$PRE_LAUNCH"; STRACE="" && [ "$USE_STRACE" = "1" ] && STRACE="strace -e trace=none -o /dev/null -f"; PADSP="" && [ "$USE_PADSP" = "1" ] && PADSP="padsp"; CMD=""; if [ -n "$LAUNCH_CMD" ]; then CMD="$LAUNCH_CMD"; elif [ -e "${GAME_NAME}.sh" ]; then CMD="./${GAME_NAME}.sh"; elif [ -e "${GAME_NAME}.dynamic" ]; then CMD="./${GAME_NAME}.dynamic -nologin"; else CMD="./${GAME_NAME}"; fi; exec $STRACE $PADSP $CMD'
